---
import { PROFILE, LINKS, OUTPUTS } from '../../data/profile';
import LinkIcons from '../icons/LinkIcons.astro';

const now = new Date();
const yyyy = now.getFullYear();
const mm = String(now.getMonth() + 1).padStart(2, '0');
const dd = String(now.getDate()).padStart(2, '0');
const dateFull = `${yyyy}/${mm}/${dd}`;
const dayPad = `0${dd}`;

const asciiTop = '╳━━━━━━━━━━━━━━━━━━━━━━━━━━━━╳';
const asciiBottom = '╳━━━━━━━━━━━━━━━━━━━━━━━━━━━━╳';

const stripeColors = ['#ff2d8d', '#16f0ff', '#ffd200', '#00ff88', '#ff3b3b', '#ffffff', '#7d4eff', '#ff8a00'];
---

<div class="gl">
  <canvas class="gl-particles" aria-hidden="true"></canvas>

  <div class="gl-content">
    <header class="gl-bar">
      <span class="gl-pink">● REC</span>
      <span class="gl-cyan" data-glitch-ch>CH.{dayPad}</span>
      <span class="gl-spacer"></span>
      <span class="gl-mono gl-clock" data-glitch-clock>--:--:--</span>
      <span class="gl-yel gl-mono" data-glitch-mhz>142.7MHz</span>
    </header>

    <section class="gl-hero">
      <span class="gl-tag">[ NFC ] HUMAN_DETECTED</span>

      <div class="gl-name-shake" data-glitch-shake>
        <span class="gl-rgb gl-glitch-text" data-text={PROFILE.name}>{PROFILE.name}</span>
      </div>

      <div class="gl-mono gl-line">
        // @{PROFILE.handle} · {PROFILE.title.toLowerCase()} · {PROFILE.location.toLowerCase()}
      </div>

      <div class="gl-mono gl-tagline gl-cyan">
        <span data-glitch-typewriter data-text="SIGNAL_LOST · RECONNECTING · HUMAN_FOUND"></span><span class="gl-cursor"></span>
      </div>

      <div class="gl-stripe" data-glitch-stripe>
        {stripeColors.map((c) => <i style={`--c:${c}`}></i>)}
      </div>
    </section>

    <section class="gl-card" data-tag="ABOUT.TXT">
      <div class="gl-bio-en">{PROFILE.bio}</div>
      <div class="gl-bio-ja">{PROFILE.bioJa}</div>
    </section>

    <h2 class="gl-h2" data-glitch-shake><span class="gl-h2-dot"></span><span class="gl-glitch-text" data-text="LINKS">LINKS</span></h2>
    <div class="gl-links">
      {LINKS.map((l) => (
        <a
          href={l.url}
          class="gl-link"
          title={`${l.label} · ${l.handle}`}
          target={l.url.startsWith('mailto:') ? undefined : '_blank'}
          rel={l.url.startsWith('mailto:') ? undefined : 'noopener noreferrer'}
        >
          <span class="ic"><LinkIcons id={l.id} /></span>
          <span class="lab">{l.label}</span>
        </a>
      ))}
    </div>

    <h2 class="gl-h2" data-glitch-shake><span class="gl-h2-dot"></span><span class="gl-glitch-text" data-text="OUTPUT">OUTPUT</span></h2>
    <div class="gl-output gl-card" data-tag="STREAM">
      {OUTPUTS.map((o) => (
        <a href={o.url} class="gl-output-row" target="_blank" rel="noopener noreferrer">
          <span class="gl-mono gl-output-mark gl-yel" data-glitch-date>{dateFull}</span>
          <span class={`gl-mono gl-output-badge gl-badge-${o.badge.toLowerCase()}`}>[{o.badge}]</span>
          <span class="gl-output-title">{o.title}</span>
        </a>
      ))}
    </div>

    <pre class="gl-ascii">{asciiTop}
   vivibio / @{PROFILE.handle} :: END_OF_TRANSMISSION :: <span data-glitch-day>{dayPad}</span>
{asciiBottom}</pre>
  </div>
</div>

<style>
  .gl {
    position: relative;
    min-height: 100dvh;
    overflow: hidden;
    color: #fff;
  }

  /* Particle canvas — full coverage, behind content */
  .gl-particles {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 1;
  }

  /* Scanline overlay */
  .gl::before {
    content: '';
    position: fixed;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      rgba(255, 0, 180, 0.04) 0 1px,
      transparent 1px 2px
    );
    pointer-events: none;
    z-index: 5;
  }

  /* Scanbeam — slow-moving white sweep */
  .gl::after {
    content: '';
    position: fixed;
    inset: 0;
    background: linear-gradient(
      180deg,
      transparent 0 49%,
      rgba(255, 255, 255, 0.05) 49.5% 50%,
      transparent 50% 100%
    );
    animation: gl-scan 7s linear infinite;
    pointer-events: none;
    z-index: 6;
  }
  @keyframes gl-scan {
    from { transform: translateY(-100%); }
    to { transform: translateY(100%); }
  }

  .gl-content {
    position: relative;
    z-index: 2;
    padding: 16px;
    max-width: 960px;
    margin: 0 auto;
  }

  @media (min-width: 768px) {
    .gl-content {
      padding: 24px 32px 60px;
    }
  }

  .gl-mono {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
  }
  .gl-pink { color: #ff2d8d; }
  .gl-cyan { color: #16f0ff; }
  .gl-yel  { color: #ffd200; }
  .gl-grn  { color: #00ff88; }

  /* Top bar */
  .gl-bar {
    display: flex;
    gap: 10px;
    align-items: center;
    font-size: 10px;
    padding-bottom: 14px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    letter-spacing: 0.06em;
  }
  .gl-spacer { flex: 1; }

  /* Hero */
  .gl-hero {
    padding: 28px 0 8px;
  }
  .gl-tag {
    display: inline-block;
    padding: 4px 10px;
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    background: #ff2d8d;
    color: #07010d;
    font-weight: 800;
    margin-bottom: 16px;
  }

  /* RGB-shifted name */
  .gl-name-shake { display: inline-block; }
  .gl-rgb {
    position: relative;
    display: inline-block;
    line-height: 0.85;
    font-weight: 900;
    font-size: clamp(48px, 13vw, 120px);
    letter-spacing: -0.04em;
    text-transform: uppercase;
    color: #fff;
    font-family: 'Inter', 'Helvetica Neue', sans-serif;
  }
  /* Generic glitch text — RGB shift driven by --gl-shift-x/y/skew CSS vars
     Per-element --shift-mult lets headings tone the wobble down for legibility. */
  .gl-glitch-text {
    position: relative;
    display: inline-block;
    --shift-mult: 1;
  }
  .gl-glitch-text::before,
  .gl-glitch-text::after {
    content: attr(data-text);
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    mix-blend-mode: screen;
    pointer-events: none;
    will-change: transform;
  }
  .gl-glitch-text::before {
    color: #ff2d8d;
    transform: translate(
        calc(var(--gl-shift-x, -3px) * var(--shift-mult)),
        calc(var(--gl-shift-y, 1px) * var(--shift-mult))
      )
      skewX(calc(var(--gl-skew, 0deg) * var(--shift-mult) * -1));
  }
  .gl-glitch-text::after {
    color: #16f0ff;
    transform: translate(
        calc(var(--gl-shift-x, -3px) * var(--shift-mult) * -1),
        calc(var(--gl-shift-y, 1px) * var(--shift-mult) * -1)
      )
      skewX(calc(var(--gl-skew, 0deg) * var(--shift-mult)));
  }
  /* Tone the wobble down for headings so titles stay readable */
  .gl-h2 .gl-glitch-text {
    --shift-mult: 0.45;
  }

  .gl-line {
    font-size: 12px;
    opacity: 0.75;
    margin-top: 18px;
    letter-spacing: 0.04em;
  }
  .gl-tagline {
    margin-top: 10px;
    font-size: 11px;
    min-height: 1.4em;
  }
  .gl-cursor {
    display: inline-block;
    width: 7px;
    height: 12px;
    margin-left: 2px;
    vertical-align: -1px;
    background: #16f0ff;
    animation: gl-blink 1s steps(2) infinite;
  }
  @keyframes gl-blink {
    50% { opacity: 0; }
  }

  .gl-stripe {
    display: flex;
    gap: 4px;
    margin-top: 22px;
    align-items: flex-end;
    height: 36px;
    isolation: isolate;
  }
  .gl-stripe i {
    display: block;
    flex: 1;
    height: var(--h, 14px);
    background: linear-gradient(to top, var(--c) 0%, var(--c) 35%, transparent 100%);
    position: relative;
    will-change: height;
    z-index: 1;
  }
  /* Far afterimage — heavily blurred, lags more */
  .gl-stripe i::before {
    content: '';
    position: absolute;
    bottom: 0;
    left: -4px;
    right: -4px;
    height: var(--gh, 14px);
    background: linear-gradient(to top, var(--c) 0%, var(--c) 30%, transparent 100%);
    filter: blur(7px);
    opacity: 0.7;
    z-index: -1;
    pointer-events: none;
  }
  /* Near afterimage — lightly blurred, lags slightly */
  .gl-stripe i::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: -1px;
    right: -1px;
    height: var(--gh2, 14px);
    background: linear-gradient(to top, var(--c) 0%, var(--c) 35%, transparent 100%);
    filter: blur(2px);
    opacity: 0.55;
    z-index: -1;
    pointer-events: none;
  }

  /* Cards */
  .gl-card {
    padding: 16px;
    border: 1px solid rgba(255, 255, 255, 0.15);
    background: rgba(255, 255, 255, 0.03);
    margin: 24px 0;
    position: relative;
  }
  .gl-card::before {
    content: attr(data-tag);
    position: absolute;
    top: -1px;
    left: -1px;
    padding: 3px 8px;
    background: #16f0ff;
    color: #07010d;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 9px;
    font-weight: 800;
    letter-spacing: 0.14em;
  }
  .gl-bio-en {
    font-size: 14px;
    line-height: 1.55;
    margin-top: 12px;
  }
  .gl-bio-ja {
    font-size: 12px;
    line-height: 1.7;
    margin-top: 12px;
    opacity: 0.65;
    word-break: auto-phrase;
    line-break: strict;
  }

  /* Section heading */
  .gl-h2 {
    font-size: 24px;
    font-weight: 900;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    margin: 28px 0 10px;
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: 'Inter', sans-serif;
  }
  .gl-h2-dot {
    display: inline-block;
    width: 10px;
    height: 10px;
    background: #ff2d8d;
    box-shadow: 0 0 14px #ff2d8d;
  }

  /* Links grid (icon + label) */
  .gl-links {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    gap: 6px;
  }
  .gl-link {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 12px;
    border: 1px solid rgba(255, 255, 255, 0.15);
    background: rgba(255, 255, 255, 0.03);
    text-decoration: none;
    color: #fff;
    transition: transform 0.12s ease, color 0.12s ease, border-color 0.12s ease, box-shadow 0.12s ease;
    position: relative;
    overflow: hidden;
    min-width: 0;
  }
  .gl-link:hover,
  .gl-link:active {
    border-color: #ff2d8d;
    color: #ff2d8d;
    transform: translate(-1px, -1px);
    box-shadow: 3px 3px 0 #16f0ff;
  }
  .gl-link .ic {
    width: 22px;
    height: 22px;
    flex-shrink: 0;
  }
  .gl-link .lab {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    min-width: 0;
  }

  @media (min-width: 640px) {
    .gl-links {
      grid-template-columns: repeat(auto-fill, minmax(170px, 1fr));
    }
    .gl-link .lab {
      font-size: 12px;
    }
  }

  /* Output (feed style) */
  .gl-output {
    padding: 8px 16px;
  }
  .gl-output-row {
    display: grid;
    grid-template-columns: auto auto 1fr;
    gap: 10px;
    align-items: baseline;
    padding: 10px 0;
    border-bottom: 1px dashed rgba(255, 255, 255, 0.1);
    text-decoration: none;
    color: #fff;
    transition: color 0.12s ease;
  }
  .gl-output-row:last-child {
    border-bottom: 0;
  }
  .gl-output-row:hover {
    color: #ff2d8d;
  }
  .gl-output-mark {
    font-size: 11px;
    font-weight: 700;
  }
  .gl-output-badge {
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.1em;
  }
  .gl-badge-article { color: #ff2d8d; }
  .gl-badge-talk    { color: #ffd200; }
  .gl-badge-repo    { color: #00ff88; }
  .gl-badge-slide   { color: #16f0ff; }
  .gl-output-title {
    font-size: 13px;
    line-height: 1.4;
  }

  /* ASCII footer */
  .gl-ascii {
    margin-top: 32px;
    margin-bottom: 24px;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    white-space: pre;
    font-size: 10px;
    line-height: 1.05;
    color: #ff2d8d;
    opacity: 0.7;
    text-align: center;
    /* Windows のスクロールバーが顕在化しないよう clip。clip 未対応環境向けに hidden もフォールバック */
    overflow-x: hidden;
    overflow-x: clip;
  }

  /* Glitch shake animation */
  @keyframes gl-shake {
    0%, 100% { transform: translate(0, 0); }
    25% { transform: translate(-3px, 1px); }
    50% { transform: translate(2px, -2px); }
    75% { transform: translate(-1px, 2px); }
  }
  .gl-shake {
    animation: gl-shake 0.18s steps(2) 1;
  }
</style>

<script>
  // Run only when Glitch theme is active (lazy init via observer)
  function initGlitchEffects() {
    // Already initialized?
    if ((window as any).__glitchInited) return;
    (window as any).__glitchInited = true;

    // ----- Clock -----
    const clockEl = document.querySelector<HTMLElement>('[data-glitch-clock]');
    if (clockEl) {
      const tick = () => {
        const now = new Date();
        const hh = String(now.getHours()).padStart(2, '0');
        const mm = String(now.getMinutes()).padStart(2, '0');
        const ss = String(now.getSeconds()).padStart(2, '0');
        clockEl.textContent = `${hh}:${mm}:${ss}`;
      };
      tick();
      setInterval(tick, 1000);
    }

    // ----- Date stamps (CH / OUTPUT row / ASCII footer) -----
    {
      const today = new Date();
      const yyyy = today.getFullYear();
      const mm = String(today.getMonth() + 1).padStart(2, '0');
      const dd = String(today.getDate()).padStart(2, '0');
      const fullDate = `${yyyy}/${mm}/${dd}`;
      const padDay = `0${dd}`;
      document.querySelectorAll<HTMLElement>('[data-glitch-date]').forEach((el) => {
        el.textContent = fullDate;
      });
      document.querySelectorAll<HTMLElement>('[data-glitch-day]').forEach((el) => {
        el.textContent = padDay;
      });
      document.querySelectorAll<HTMLElement>('[data-glitch-ch]').forEach((el) => {
        el.textContent = `CH.${padDay}`;
      });
    }

    // ----- MHz random scanner (XXX.X format, very fast) -----
    const mhzEl = document.querySelector<HTMLElement>('[data-glitch-mhz]');
    if (mhzEl) {
      const updateMhz = () => {
        const intPart = 100 + Math.floor(Math.random() * 900); // 100–999
        const decPart = Math.floor(Math.random() * 10);        // 0–9
        mhzEl.textContent = `${intPart}.${decPart}MHz`;
      };
      updateMhz();
      setInterval(updateMhz, 55);
    }

    // ----- Typewriter -----
    const tw = document.querySelector<HTMLElement>('[data-glitch-typewriter]');
    if (tw) {
      const text = tw.dataset.text ?? '';
      let i = 0;
      const speed = 35;
      const pauseAtEnd = 2200;
      const step = () => {
        if (i <= text.length) {
          tw.textContent = text.slice(0, i);
          i++;
          setTimeout(step, speed);
        } else {
          // Hold then restart
          setTimeout(() => {
            i = 0;
            step();
          }, pauseAtEnd);
        }
      };
      step();
    }

    // ----- Periodic glitch shake on every [data-glitch-shake] element -----
    const shakeEls = document.querySelectorAll<HTMLElement>('[data-glitch-shake]');
    shakeEls.forEach((el) => {
      const interval = 1500 + Math.random() * 2000;
      setInterval(() => {
        if (Math.random() > 0.5) {
          el.classList.add('gl-shake');
          setTimeout(() => el.classList.remove('gl-shake'), 200);
        }
      }, interval);
    });

    // ----- Audio-waveform stripe with two-layer afterimage -----
    const stripe = document.querySelector<HTMLElement>('[data-glitch-stripe]');
    if (stripe) {
      const bars = Array.from(stripe.querySelectorAll<HTMLElement>('i'));
      type Bar = {
        el: HTMLElement;
        current: number;
        target: number;
        ghost: number;
        ghost2: number;
        speed: number;
      };
      const state: Bar[] = bars.map((el) => ({
        el,
        current: Math.random(),
        target: Math.random(),
        ghost: Math.random(),
        ghost2: Math.random(),
        speed: 0.05 + Math.random() * 0.08,
      }));
      const minH = 3;
      const maxH = 32;
      const animateBars = () => {
        for (const b of state) {
          b.current += (b.target - b.current) * b.speed;
          // Far ghost lags more (stronger trail), near ghost lags less
          b.ghost += (b.current - b.ghost) * b.speed * 0.18;
          b.ghost2 += (b.current - b.ghost2) * b.speed * 0.45;
          if (Math.abs(b.current - b.target) < 0.04) {
            b.target = Math.random();
          }
          const h = minH + b.current * (maxH - minH);
          const gh = minH + b.ghost * (maxH - minH);
          const gh2 = minH + b.ghost2 * (maxH - minH);
          b.el.style.setProperty('--h', `${h.toFixed(2)}px`);
          b.el.style.setProperty('--gh', `${gh.toFixed(2)}px`);
          b.el.style.setProperty('--gh2', `${gh2.toFixed(2)}px`);
        }
        requestAnimationFrame(animateBars);
      };
      animateBars();
    }

    // ----- Glitch RGB-shift wobble (animates --gl-shift-x/y/skew on .gl) -----
    // Baseline -3px / 1px keeps the canonical RGB shift; small wobble adds breathing.
    const glContainer = document.querySelector<HTMLElement>('.gl');
    if (glContainer) {
      let glStart = 0;
      const animateShift = (time: number) => {
        if (glStart === 0) glStart = time;
        const t = (time - glStart) / 1000;
        const x = -3 + Math.sin(t * 1.3) * 0.9 + Math.sin(t * 4.7) * 0.25;
        const y = 1 + Math.cos(t * 1.0) * 0.45 + Math.sin(t * 2.9) * 0.18;
        const skew = Math.sin(t * 0.5) * 0.32;
        glContainer.style.setProperty('--gl-shift-x', `${x.toFixed(2)}px`);
        glContainer.style.setProperty('--gl-shift-y', `${y.toFixed(2)}px`);
        glContainer.style.setProperty('--gl-skew', `${skew.toFixed(2)}deg`);
        requestAnimationFrame(animateShift);
      };
      requestAnimationFrame(animateShift);
    }

    // ----- Particle canvas + periodic rocket -----
    const canvas = document.querySelector<HTMLCanvasElement>('.gl-particles');
    if (canvas) {
      const ctx = canvas.getContext('2d');
      if (ctx) {
        const dpr = Math.min(2, window.devicePixelRatio || 1);
        let w = 0;
        let h = 0;
        const COUNT = 50;
        const COLOR = '#ff2d8d';
        const LINK_DIST = 80;

        type P = { x: number; y: number; vx: number; vy: number; r: number; ttl: number; maxTtl: number };
        const particles: P[] = [];
        const MAX_PARTICLES = 2000;
        const FADE_FRAMES = 90;

        type Rocket = { x: number; y: number; vx: number; active: boolean };
        const rocket: Rocket = { x: -100, y: 0, vx: 0, active: false };
        const ROCKET_RADIUS = 110;

        function resize() {
          if (!canvas || !ctx) return;
          w = canvas.clientWidth;
          h = canvas.clientHeight;
          canvas.width = w * dpr;
          canvas.height = h * dpr;
          ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
        }

        function spawn() {
          particles.length = 0;
          for (let i = 0; i < COUNT; i++) {
            particles.push({
              x: Math.random() * w,
              y: Math.random() * h,
              vx: (Math.random() - 0.5) * 0.3,
              vy: (Math.random() - 0.5) * 0.3,
              r: Math.random() * 1.4 + 0.4,
              ttl: Infinity, // base field lives forever
              maxTtl: Infinity,
            });
          }
        }

        type RocketExt = Rocket & { vy: number };
        const rocketExt = rocket as RocketExt;
        rocketExt.vy = 0;

        function launchRocket() {
          rocketExt.active = true;
          // Pick a spawn edge (0=top, 1=right, 2=bottom, 3=left), 40px outside the canvas
          const side = Math.floor(Math.random() * 4);
          let sx = 0;
          let sy = 0;
          if (side === 0) { sx = Math.random() * w; sy = -50; }
          else if (side === 1) { sx = w + 50; sy = Math.random() * h; }
          else if (side === 2) { sx = Math.random() * w; sy = h + 50; }
          else { sx = -50; sy = Math.random() * h; }
          rocketExt.x = sx;
          rocketExt.y = sy;
          // Aim somewhere near the opposite side with random offset for variety
          const targetX = w - sx + (Math.random() - 0.5) * w * 0.5;
          const targetY = h - sy + (Math.random() - 0.5) * h * 0.5;
          const dx = targetX - sx;
          const dy = targetY - sy;
          const dist = Math.sqrt(dx * dx + dy * dy) || 1;
          // Mobile viewports get a slower rocket so the cross-screen time feels similar
          const isNarrow = w < 700;
          const speed = isNarrow
            ? 1.8 + Math.random() * 1.0   // 1.8–2.8 px/frame on mobile
            : 2.5 + Math.random() * 1.0;  // 2.5–3.5 px/frame on desktop
          rocketExt.vx = (dx / dist) * speed;
          rocketExt.vy = (dy / dist) * speed;
        }

        function scheduleRocket() {
          const delay = 7000 + Math.random() * 6000; // 7–13 s between launches
          setTimeout(() => {
            if (!rocketExt.active) launchRocket();
            scheduleRocket();
          }, delay);
        }
        // Launch the first rocket right after the canvas has been measured
        // (resize() runs after this block; without a small delay w/h are still 0
        // and the launch direction collapses to the cardinal axes).
        setTimeout(() => {
          if (!rocketExt.active && w > 0 && h > 0) launchRocket();
        }, 80);
        scheduleRocket();

        function drawRocket() {
          if (!ctx || !rocketExt.active) return;
          const angle = Math.atan2(rocketExt.vy, rocketExt.vx);
          ctx.save();
          ctx.translate(rocketExt.x, rocketExt.y);
          ctx.rotate(angle);

          // ===== Flame trail behind rocket =====
          const FLAME_LEN = 36;
          for (let i = 0; i < FLAME_LEN; i++) {
            const t = i / FLAME_LEN;
            const tx = -i * 3.2 + (Math.random() - 0.5) * 2.5;
            const ty = (Math.random() - 0.5) * (3 + i * 0.32);
            const tr = Math.max(0.4, 5.5 - i * 0.13);
            const opacity = Math.max(0, 0.95 - t * 0.92);
            ctx.fillStyle =
              i < 3 ? '#fff' : i < 9 ? '#ffd200' : i < 18 ? '#ff5733' : '#ff2d8d';
            ctx.globalAlpha = opacity;
            ctx.beginPath();
            ctx.arc(tx, ty, tr, 0, Math.PI * 2);
            ctx.fill();
          }
          // Bright nozzle core
          for (let i = 0; i < 8; i++) {
            const tx = -2 + (Math.random() - 0.5) * 4;
            const ty = (Math.random() - 0.5) * 6;
            ctx.fillStyle = '#fff';
            ctx.globalAlpha = 0.6 + Math.random() * 0.4;
            ctx.beginPath();
            ctx.arc(tx, ty, 1.5 + Math.random() * 2, 0, Math.PI * 2);
            ctx.fill();
          }

          // ===== Rocket body =====
          ctx.globalAlpha = 1;
          // Aft fins (drawn first so body covers the inside edge)
          ctx.fillStyle = '#ff2d8d';
          // Top fin
          ctx.beginPath();
          ctx.moveTo(0, -3);
          ctx.lineTo(-6, -7);
          ctx.lineTo(4, -3);
          ctx.closePath();
          ctx.fill();
          // Bottom fin
          ctx.beginPath();
          ctx.moveTo(0, 3);
          ctx.lineTo(-6, 7);
          ctx.lineTo(4, 3);
          ctx.closePath();
          ctx.fill();
          // Main body — capsule with cyan top, white belly
          ctx.fillStyle = '#16f0ff';
          ctx.fillRect(0, -3, 16, 6);
          // Belly stripe
          ctx.fillStyle = 'rgba(255,255,255,0.65)';
          ctx.fillRect(0, 1, 16, 2);
          // Nose cone
          ctx.fillStyle = '#fff';
          ctx.beginPath();
          ctx.moveTo(16, -3);
          ctx.lineTo(24, 0);
          ctx.lineTo(16, 3);
          ctx.closePath();
          ctx.fill();
          // Window/port
          ctx.fillStyle = '#ffd200';
          ctx.beginPath();
          ctx.arc(11, -0.5, 1.6, 0, Math.PI * 2);
          ctx.fill();
          ctx.fillStyle = '#07010d';
          ctx.beginPath();
          ctx.arc(11, -0.5, 0.7, 0, Math.PI * 2);
          ctx.fill();
          // Body band detail
          ctx.fillStyle = 'rgba(7,1,13,0.5)';
          ctx.fillRect(5, -3, 1, 6);

          ctx.restore();

          // ===== Spawn persistent exhaust particles into the main field =====
          // Spawn in a V-cone behind the rocket: further back = wider lateral spread.
          // Continuous spawn throughout flight — when at cap, evict the oldest
          // exhaust particle (FIFO) so the rocket keeps emitting until off-screen.
          {
            const speed = Math.sqrt(rocketExt.vx * rocketExt.vx + rocketExt.vy * rocketExt.vy) || 1;
            const ux = rocketExt.vx / speed;
            const uy = rocketExt.vy / speed;
            const perpX = -uy;
            const perpY = ux;
            for (let n = 0; n < 2; n++) {
              // Make room if we're at the cap by evicting the particle closest to
              // natural expiry (lowest remaining TTL) rather than the oldest one,
              // so freshly-spawned exhaust isn't sacrificed prematurely.
              if (particles.length >= MAX_PARTICLES) {
                let minTtl = Infinity;
                let minIdx = -1;
                for (let i = 0; i < particles.length; i++) {
                  const ttl = particles[i].ttl;
                  if (ttl !== Infinity && ttl < minTtl) {
                    minTtl = ttl;
                    minIdx = i;
                  }
                }
                if (minIdx >= 0) {
                  particles.splice(minIdx, 1);
                } else {
                  break; // only base field present — bail
                }
              }
              const back = 24 + Math.random() * 90;        // 24–114 px behind nozzle
              const halfWidth = back * 0.22;               // V-cone half-width (~12°)
              const side = (Math.random() - 0.5) * 2 * halfWidth;
              const radialSign = side >= 0 ? 1 : -1;
              const radial = 0.35 + Math.random() * 0.6;   // continued outward drift
              const fwd = -0.25 - Math.random() * 0.35;    // slight backward drift in rocket frame
              const px = rocketExt.x - ux * back + perpX * side;
              const py = rocketExt.y - uy * back + perpY * side;
              // Skip spawns that land too far off-canvas — they'd be invisible
              if (px < -40 || px > w + 40 || py < -40 || py > h + 40) continue;
              const maxTtl = 1080 + Math.floor(Math.random() * 600); // 18–28 s @60fps
              particles.push({
                x: px,
                y: py,
                vx: ux * fwd + perpX * radial * radialSign,
                vy: uy * fwd + perpY * radial * radialSign,
                r: Math.random() * 1.4 + 0.4,
                ttl: maxTtl,
                maxTtl,
              });
            }
          }
        }

        let raf = 0;
        function tick() {
          if (!ctx) return;
          ctx.clearRect(0, 0, w, h);

          // Advance rocket
          if (rocketExt.active) {
            rocketExt.x += rocketExt.vx;
            rocketExt.y += rocketExt.vy;
            if (
              rocketExt.x < -100 ||
              rocketExt.x > w + 100 ||
              rocketExt.y < -100 ||
              rocketExt.y > h + 100
            ) {
              rocketExt.active = false;
            }
          }

          // Update particles (reverse loop so we can splice expired ones)
          for (let i = particles.length - 1; i >= 0; i--) {
            const p = particles[i];
            // TTL countdown for finite-life particles (rocket exhaust)
            if (p.ttl !== Infinity) {
              p.ttl--;
              if (p.ttl <= 0) {
                particles.splice(i, 1);
                continue;
              }
            }
            // Rocket dispersion: push particles radially away from the rocket
            if (rocketExt.active) {
              const dx = p.x - rocketExt.x;
              const dy = p.y - rocketExt.y;
              const d2 = dx * dx + dy * dy;
              if (d2 < ROCKET_RADIUS * ROCKET_RADIUS && d2 > 1) {
                const d = Math.sqrt(d2);
                const force = 1.6 * (1 - d / ROCKET_RADIUS);
                p.vx += (dx / d) * force;
                p.vy += (dy / d) * force;
              }
            }
            // Soft damping so dispersed particles eventually settle
            p.vx *= 0.992;
            p.vy *= 0.992;
            // Tiny brownian impulse keeps the field alive at rest
            p.vx += (Math.random() - 0.5) * 0.02;
            p.vy += (Math.random() - 0.5) * 0.02;
            // Velocity clamp to avoid runaway speeds
            const v = Math.sqrt(p.vx * p.vx + p.vy * p.vy);
            const MAX_V = 4;
            if (v > MAX_V) {
              p.vx = (p.vx / v) * MAX_V;
              p.vy = (p.vy / v) * MAX_V;
            }
            // Integrate
            p.x += p.vx;
            p.y += p.vy;
            if (p.ttl === Infinity) {
              // Base field wraps toroidally so it always covers the canvas
              if (p.x < 0) p.x += w;
              if (p.x > w) p.x -= w;
              if (p.y < 0) p.y += h;
              if (p.y > h) p.y -= h;
            } else {
              // Exhaust particles fly off naturally — kill once well off-screen
              if (p.x < -120 || p.x > w + 120 || p.y < -120 || p.y > h + 120) {
                p.ttl = 0;
              }
            }
            // Render: exhaust particles cool from magenta to cyan as they age,
            // and fade out in the final FADE_FRAMES of their TTL.
            let alpha = 0.7;
            let cr = 255, cg = 45, cb = 141; // magenta baseline
            if (p.ttl !== Infinity) {
              const age = 1 - p.ttl / p.maxTtl;
              if (age > 0.15) {
                const t = Math.min(1, (age - 0.15) / 0.45);
                const eased = t * t * (3 - 2 * t); // smoothstep
                cr = Math.round(255 + (22 - 255) * eased);
                cg = Math.round(45 + (240 - 45) * eased);
                cb = Math.round(141 + (255 - 141) * eased);
              }
              if (p.ttl < FADE_FRAMES) alpha *= p.ttl / FADE_FRAMES;
            }
            ctx.fillStyle = `rgb(${cr},${cg},${cb})`;
            ctx.globalAlpha = alpha;
            ctx.beginPath();
            ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
            ctx.fill();
          }

          // Linking lines — only between base-field particles, so exhaust dots
          // don't form a noisy mesh during/after rocket bursts.
          ctx.strokeStyle = COLOR;
          ctx.lineWidth = 0.5;
          for (let i = 0; i < particles.length; i++) {
            if (particles[i].ttl !== Infinity) continue;
            for (let j = i + 1; j < particles.length; j++) {
              if (particles[j].ttl !== Infinity) continue;
              const dx = particles[i].x - particles[j].x;
              const dy = particles[i].y - particles[j].y;
              const d2 = dx * dx + dy * dy;
              if (d2 < LINK_DIST * LINK_DIST) {
                ctx.globalAlpha = 0.15 * (1 - Math.sqrt(d2) / LINK_DIST);
                ctx.beginPath();
                ctx.moveTo(particles[i].x, particles[i].y);
                ctx.lineTo(particles[j].x, particles[j].y);
                ctx.stroke();
              }
            }
          }

          drawRocket();

          raf = requestAnimationFrame(tick);
        }

        resize();
        spawn();
        let lastW = w;
        tick();

        // Mobile では URL バー折りたたみで viewport 高さだけ変わって再発火するため、
        // 幅が大きく変わったとき (オリエンテーション変更/ウィンドウリサイズ) だけ
        // 粒子を再生成する。高さ変化だけのときは canvas dims のみ更新して粒子は維持。
        const ro = new ResizeObserver(() => {
          resize();
          if (Math.abs(w - lastW) > 60) {
            lastW = w;
            spawn();
          }
        });
        ro.observe(canvas);

        // Pause animation when tab is hidden to save CPU
        document.addEventListener('visibilitychange', () => {
          if (document.hidden) {
            cancelAnimationFrame(raf);
          } else {
            tick();
          }
        });
      }
    }
  }

  // Run on initial load if already on Glitch theme, otherwise wait
  if (document.documentElement.dataset.theme === 'glitch') {
    initGlitchEffects();
  } else {
    // Watch for theme changes; init once Glitch becomes active
    const observer = new MutationObserver(() => {
      if (document.documentElement.dataset.theme === 'glitch') {
        initGlitchEffects();
        observer.disconnect();
      }
    });
    observer.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
  }
</script>
