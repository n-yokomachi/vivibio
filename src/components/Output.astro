---
import { OUTPUTS } from '../data/profile.ts';

const today = new Date().toISOString().slice(0, 10);
---

<section class="mn-section">
  <div class="mn-section-h">
    <h2>Output</h2>
    <span class="count mn-mono">{today}</span>
  </div>
  <div class="mn-outputs">
    {
      OUTPUTS.map((o) => (
        <a href={o.url} class="mn-out" target="_blank" rel="noopener noreferrer">
          <span class="badge mn-mono">{o.badge}</span>
          <div class="body">
            <div class="title">{o.title}</div>
            <div class="sub">{o.subtitle}</div>
          </div>
          <span class="arrow" aria-hidden="true">↗</span>
        </a>
      ))
    }
  </div>
</section>

<style>
  .mn-section {
    margin-top: 44px;
  }
  .mn-section-h {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 14px;
  }
  .mn-section-h h2 {
    font-size: 13px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 600;
    margin: 0;
    color: rgba(26, 26, 26, 0.55);
  }
  .mn-section-h .count {
    font-size: 11px;
    color: rgba(26, 26, 26, 0.4);
  }
  .mn-mono {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
  }

  .mn-outputs {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .mn-out {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 14px;
    padding: 14px 16px;
    border-radius: 12px;
    border: 1px solid rgba(26, 26, 26, 0.1);
    background: #fff;
    text-decoration: none;
    color: inherit;
    transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
  }
  .mn-out:hover,
  .mn-out:active {
    border-color: rgba(26, 26, 26, 0.4);
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(26, 26, 26, 0.06);
  }
  .badge {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.14em;
    color: #ff5733;
    padding: 4px 8px;
    border: 1px solid rgba(255, 87, 51, 0.4);
    border-radius: 4px;
    align-self: flex-start;
  }
  .body {
    min-width: 0;
  }
  .title {
    font-size: 14px;
    font-weight: 500;
    line-height: 1.35;
    color: #1a1a1a;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }
  .sub {
    font-size: 11px;
    color: rgba(26, 26, 26, 0.5);
    margin-top: 4px;
    letter-spacing: 0.02em;
  }
  .arrow {
    font-size: 14px;
    color: rgba(26, 26, 26, 0.35);
    align-self: center;
  }
</style>
