---
import { PROFILE, LINKS, CREDENTIALS } from '../data/profile';

interface Props {
  title?: string;
  description?: string;
}

const SITE_URL = Astro.site?.href ?? 'https://vivibio.pages.dev';

const {
  title = 'Naoki Yokomachi (横町直樹) | vivibio',
  description = 'vivibio — digital business card of Naoki Yokomachi (横町直樹・よこまち / yoko / _cityside / yokomachi), Software Engineer / AI Engineer based in Tokyo, Japan. AWS Community Builders (AI Engineering).',
} = Astro.props;

// SEO: schema.org Person（検索エンジン向けの不可視データ。
// 横町直樹 / よこまち / yoko / yokomachi / _cityside など想定される表記ゆれをここで網羅する）
const SAME_AS_IDS = ['github', 'x', 'huggingface', 'zenn', 'qiita', 'devto', 'speakerdeck', 'linkedin', 'note'];
const personJsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Person',
  '@id': SITE_URL + '#person',
  name: PROFILE.name,
  givenName: 'Naoki',
  familyName: 'Yokomachi',
  alternateName: [
    '横町直樹',
    '横町 直樹',
    'よこまち なおき',
    'よこまち',
    'ヨコマチ ナオキ',
    'Yokomachi Naoki',
    'yokomachi',
    'yoko',
    '_cityside',
  ],
  jobTitle: PROFILE.title,
  description: PROFILE.bio,
  image: PROFILE.avatarUrl,
  url: SITE_URL,
  mainEntityOfPage: SITE_URL,
  address: { '@type': 'PostalAddress', addressLocality: 'Tokyo', addressCountry: 'JP' },
  award: [...CREDENTIALS],
  knowsAbout: ['AWS', 'Generative AI', 'AI Agents', 'Amazon Bedrock', 'TypeScript', 'Python'],
  sameAs: LINKS.filter((l) => SAME_AS_IDS.includes(l.id)).map((l) => l.url),
});

// SERP に表示されるサイト名(pages.dev サブドメインだと親ブランドの
// Cloudflare にフォールバックされるため、WebSite 構造化データで明示する)
const websiteJsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'vivibio',
  alternateName: 'Vivibio',
  url: SITE_URL,
});
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta
      name="keywords"
      content="横町直樹, 横町 直樹, よこまち, よこまちなおき, Naoki Yokomachi, yokomachi, yoko, _cityside, Software Engineer, AI Engineer, AWS"
    />
    <title>{title}</title>
    <meta name="google-site-verification" content="63GunHCxpC6xKtACdB8ybuFFJQ5VLM-xH5-HTkhkzlo" />
    <link rel="canonical" href={SITE_URL} />
    <meta name="theme-color" content="#000000" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;700&family=Space+Grotesk:wght@400;500;700;900&family=Caveat:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="profile" />
    <meta property="og:url" content={SITE_URL} />
    <meta property="og:site_name" content="vivibio" />
    <meta property="og:image" content={PROFILE.avatarUrl} />
    <meta property="og:locale" content="ja_JP" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:site" content="@_cityside" />
    <script type="application/ld+json" set:html={personJsonLd} />
    <script type="application/ld+json" set:html={websiteJsonLd} />

    <script is:inline>
      (function () {
        try {
          var hash = location.hash.slice(1);
          var allowed = ['void', 'minimal', 'glitch', 'particle', 'concrete'];
          document.documentElement.dataset.theme = allowed.indexOf(hash) >= 0 ? hash : 'void';
        } catch (e) {
          document.documentElement.dataset.theme = 'void';
        }
      })();
    </script>
    <noscript>
      <style>
        .theme-pane[data-theme='void'] {
          position: relative;
          height: auto;
          overflow: visible;
          opacity: 1;
          visibility: visible;
        }
      </style>
    </noscript>
  </head>
  <body>
    <slot />

    <style is:global>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
      }
      html,
      body {
        margin: 0;
        padding: 0;
        min-height: 100%;
      }
      html {
        overflow-x: hidden;
      }

      :root {
        --void-accent: #ff4d9e;
      }
      /* Fallback before data-theme attribute is set (no-JS / pre-script paint).
         The entry gate paints black first, so the fallback is dark. */
      body {
        background: #000;
        color: #9a9a9a;
        font-family: 'JetBrains Mono', ui-monospace, monospace;
      }
      :root[data-theme='void'] body {
        background: #000;
        color: #9a9a9a;
        font-family: 'JetBrains Mono', ui-monospace, monospace;
      }

      :root[data-theme='minimal'] body {
        background: #f7f6f3;
        color: #1a1a1a;
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif;
      }
      :root[data-theme='glitch'] body {
        background: #07010d;
        color: #fff;
        font-family: 'Space Grotesk', 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      }
      :root[data-theme='particle'] body {
        background: #05080e;
        color: #e2efff;
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif;
      }
      :root[data-theme='concrete'] body {
        background: #e8e2d6;
        color: #1a1815;
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif;
      }
      body {
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        overscroll-behavior-y: none;
        /* Stack all theme panes in the same grid cell so they can cross-fade
           when data-theme changes. position:relative makes body the containing
           block for the absolutely-positioned inactive panes below. */
        position: relative;
        display: grid;
        grid-template-columns: 1fr;
        transition:
          background-color 0.35s ease,
          color 0.35s ease;
      }
      a {
        color: inherit;
      }
      .theme-pane {
        grid-column: 1;
        grid-row: 1;
        /* Inactive panes are taken out of flow so the document height tracks
           only the active theme. Otherwise the tallest pane (concrete) would
           stretch the shared grid cell and leave trailing whitespace under the
           shorter themes. height:100% + overflow:hidden clips each inactive
           pane to the active theme's height so it adds no extra scroll region
           (absolutely-positioned elements still extend scrollable overflow). */
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        overflow: hidden;
        opacity: 0;
        visibility: hidden;
        transition:
          opacity 0.35s ease,
          visibility 0s linear 0.35s;
      }
      :root[data-theme='void'] .theme-pane[data-theme='void'],
      :root[data-theme='minimal'] .theme-pane[data-theme='minimal'],
      :root[data-theme='glitch'] .theme-pane[data-theme='glitch'],
      :root[data-theme='particle'] .theme-pane[data-theme='particle'],
      :root[data-theme='concrete'] .theme-pane[data-theme='concrete'] {
        /* The active pane returns to normal flow and defines the page height. */
        position: relative;
        height: auto;
        overflow: visible;
        opacity: 1;
        visibility: visible;
        transition:
          opacity 0.35s ease,
          visibility 0s linear 0s;
      }
      @media (prefers-reduced-motion: reduce) {
        body { transition: none; }
        .theme-pane { transition: opacity 0s, visibility 0s; }
      }
    </style>
  </body>
</html>
